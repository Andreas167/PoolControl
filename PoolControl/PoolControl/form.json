{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "1 · Aktoren",
      "expanded": true,
      "items": [
        { "type": "Label", "bold": true, "caption": "Umwälzpumpe (UP)" },
        { "type": "Select", "name": "UpTargetMode", "caption": "Schaltziel-Typ", "options": [
          { "caption": "Variable (mit/ohne Aktion)", "value": 0 },
          { "caption": "Instanz-Aktion direkt", "value": 1 }
        ] },
        { "type": "SelectVariable", "name": "UpTargetVarId", "caption": "Schaltziel-Variable (bei Typ Variable)" },
        { "type": "SelectInstance", "name": "UpTargetInstanceId", "caption": "Ziel-Instanz (bei Typ Instanz-Aktion)" },
        { "type": "ValidationTextBox", "name": "UpTargetIdent", "caption": "Aktions-Ident (bei Typ Instanz-Aktion)" },
        { "type": "SelectVariable", "name": "UpFeedbackVarId", "caption": "Rückmeldung (optional → Open-Loop wenn leer)" },
        { "type": "SelectVariable", "name": "UpPowerVarId", "caption": "Leistungs-Messung [W] (optional)" },
        { "type": "Label", "caption": " " },
        { "type": "Label", "bold": true, "caption": "Heizung / Wärmepumpe (PH)" },
        { "type": "Select", "name": "PhTargetMode", "caption": "Schaltziel-Typ", "options": [
          { "caption": "Variable (mit/ohne Aktion)", "value": 0 },
          { "caption": "Instanz-Aktion direkt", "value": 1 }
        ] },
        { "type": "SelectVariable", "name": "PhTargetVarId", "caption": "Schaltziel-Variable (bei Typ Variable)" },
        { "type": "SelectInstance", "name": "PhTargetInstanceId", "caption": "Ziel-Instanz (bei Typ Instanz-Aktion)" },
        { "type": "ValidationTextBox", "name": "PhTargetIdent", "caption": "Aktions-Ident (bei Typ Instanz-Aktion)" },
        { "type": "SelectVariable", "name": "PhFeedbackVarId", "caption": "Rückmeldung (optional)" },
        { "type": "SelectVariable", "name": "PhPowerVarId", "caption": "Leistungs-Messung [W] (optional)" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "2 · Sensoren",
      "items": [
        { "type": "SelectVariable", "name": "PoolTempVarId", "caption": "Pool-Temperatur Ist [°C]" },
        { "type": "SelectVariable", "name": "PoolSetpointVarId", "caption": "Pool-Solltemperatur [°C]" },
        { "type": "SelectVariable", "name": "OutsideTempVarId", "caption": "Außentemperatur [°C] (für Frostschutz, optional)" },
        { "type": "SelectVariable", "name": "PvPowerVarId", "caption": "PV-Überschuss [W] (optional)" },
        { "type": "NumberSpinner", "name": "PvPowerFactor", "caption": "PV-Messwert-Faktor (z. B. -1 bei invertiertem Vorzeichen)", "digits": 2 },
        { "type": "SelectVariable", "name": "EnergyCheapVarId", "caption": "Energie-günstig-Signal [Bool] (Tarif-Modul, optional)" },
        { "type": "NumberSpinner", "name": "SensorStaleSec", "caption": "Sensor-Timeout (stale) [s]", "suffix": " s", "minimum": 0, "maximum": 3600 },
        { "type": "Label", "caption": " " },
        { "type": "Label", "bold": true, "caption": "Externe Modus-Synchronisation (optional, W5)" },
        { "type": "SelectVariable", "name": "QuickSyncVarId", "caption": "Schnellmodus-Sync [Bool]" },
        { "type": "SelectVariable", "name": "HolidaySyncVarId", "caption": "Urlaubs-Sync [Bool]" },
        { "type": "SelectVariable", "name": "ContinuousSyncVarId", "caption": "Dauerbetrieb-Sync [Bool]" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "3 · Sperrquellen (Interlocks)",
      "items": [
        { "type": "Label", "caption": "Jede Quelle kann UP, PH oder beide sperren. Bei stummem Sensor greift das Stale-Verhalten (Default: Sperre lösen)." },
        {
          "type": "List",
          "name": "LockSources",
          "caption": "Sperrquellen",
          "rowCount": 4,
          "add": true,
          "delete": true,
          "columns": [
            { "caption": "Name", "name": "name", "width": "140px", "edit": { "type": "ValidationTextBox" } },
            { "caption": "Variable", "name": "var_id", "width": "90px", "edit": { "type": "SelectVariable" } },
            { "caption": "Bedingung", "name": "condition", "width": "110px", "edit": { "type": "Select", "options": [
              { "caption": "Bool = true", "value": "bool_true" },
              { "caption": "Bool = false", "value": "bool_false" },
              { "caption": "> Schwelle", "value": "gt" },
              { "caption": "< Schwelle", "value": "lt" }
            ] } },
            { "caption": "Schwelle", "name": "threshold", "width": "70px", "edit": { "type": "NumberSpinner", "digits": 1 } },
            { "caption": "Wirkt auf", "name": "affects", "width": "90px", "edit": { "type": "Select", "options": [
              { "caption": "UP + PH", "value": "both" },
              { "caption": "Nur UP", "value": "pump" },
              { "caption": "Nur PH", "value": "heater" }
            ] } },
            { "caption": "Stale-Verhalten", "name": "stale_action", "width": "110px", "edit": { "type": "Select", "options": [
              { "caption": "Sperre lösen", "value": "loosen" },
              { "caption": "Sperre halten", "value": "hold" }
            ] } },
            { "caption": "Stale nach [s]", "name": "stale_after_sec", "width": "90px", "edit": { "type": "NumberSpinner", "minimum": 60, "maximum": 7200 } }
          ],
          "values": [
            { "name": "Schwalldusche", "var_id": 0, "condition": "gt", "threshold": 500, "affects": "both", "stale_action": "loosen", "stale_after_sec": 900 }
          ]
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "4 · Heizregelung",
      "items": [
        { "type": "NumberSpinner", "name": "HeatHysteresis", "caption": "Hysterese [K]", "suffix": " K", "digits": 1 },
        { "type": "NumberSpinner", "name": "PhMinOnSec", "caption": "Mindest-Einschaltzeit [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "PhMinOffSec", "caption": "Mindest-Ausschaltzeit [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "PumpLeadSec", "caption": "UP-Vorlauf vor PH [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "PumpTrailSec", "caption": "UP-Nachlauf nach PH [s]", "suffix": " s" },
        { "type": "CheckBox", "name": "SensorInPipe", "caption": "Temperaturfühler im Rohr (Mess-Vorlauf nötig)" },
        { "type": "NumberSpinner", "name": "SensorWarmupSec", "caption": "Mess-Vorlaufzeit [s]", "suffix": " s" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "5 · Umwälzung & Tagesplan",
      "items": [
        { "type": "NumberSpinner", "name": "Volume", "caption": "Poolvolumen [m³]", "suffix": " m³", "digits": 1 },
        { "type": "NumberSpinner", "name": "PumpFlow", "caption": "Förderleistung [m³/h]", "suffix": " m³/h", "digits": 1 },
        { "type": "NumberSpinner", "name": "CirculationFactor", "caption": "Umwälzfaktor", "digits": 1 },
        { "type": "NumberSpinner", "name": "StagnationThresholdSec", "caption": "Stagnationsschwelle [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "StagnationShare", "caption": "Pflicht-Laufanteil [0..1]", "digits": 2, "minimum": 0.05, "maximum": 1.0 },
        { "type": "NumberSpinner", "name": "DayEndHour", "caption": "Tagesende-Grenze [Uhr dezimal]", "digits": 1 },
        { "type": "Label", "bold": true, "caption": "Garantie-Soll-Kurve (monoton steigend, max 100 %)" },
        {
          "type": "List",
          "name": "CurvePoints",
          "caption": "Stützpunkte",
          "rowCount": 5,
          "add": true,
          "delete": true,
          "columns": [
            { "caption": "Uhrzeit (dezimal)", "name": "hour", "width": "150px", "edit": { "type": "NumberSpinner", "minimum": 0, "maximum": 24, "digits": 2 } },
            { "caption": "Mindest-%", "name": "pct", "width": "120px", "edit": { "type": "NumberSpinner", "minimum": 1, "maximum": 100 } }
          ],
          "values": [
            { "hour": 12.0, "pct": 40 },
            { "hour": 16.0, "pct": 80 },
            { "hour": 20.0, "pct": 100 }
          ]
        },
        { "type": "Label", "bold": true, "caption": "Temperaturabhängige Anpassung" },
        { "type": "CheckBox", "name": "TempAdjustActive", "caption": "Aktiv" },
        { "type": "Select", "name": "TempAdjustBasis", "caption": "Bezug", "options": [
          { "caption": "Wassertemperatur", "value": "water" },
          { "caption": "Heizung aktiv", "value": "heater" }
        ] },
        { "type": "NumberSpinner", "name": "TempAdjustRefTemp", "caption": "Referenztemperatur [°C]", "suffix": " °C", "digits": 1 },
        { "type": "NumberSpinner", "name": "TempAdjustHeaterBoost", "caption": "Heizungs-Boost-Faktor (bei Bezug 'Heizung aktiv')", "digits": 2, "minimum": 0, "maximum": 1 }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "6 · PV-Optimierung",
      "items": [
        { "type": "Label", "caption": "Stabilitätsbedingung (W1): Einschalt − Ausschalt ≥ P_UP + P_PH + Reserve. Wird beim Speichern geprüft." },
        { "type": "NumberSpinner", "name": "PvOnThreshold", "caption": "Einschalt-Schwelle [W]", "suffix": " W" },
        { "type": "NumberSpinner", "name": "PvOffThreshold", "caption": "Ausschalt-Schwelle [W]", "suffix": " W" },
        { "type": "NumberSpinner", "name": "PvOnDebounceSec", "caption": "Einschalt-Debounce [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "PvOffDebounceSec", "caption": "Ausschalt-Debounce [s] (Wolkenschutz)", "suffix": " s" },
        { "type": "NumberSpinner", "name": "PvStabilityReserve", "caption": "Stabilitäts-Reserve [0..1]", "digits": 2 },
        { "type": "NumberSpinner", "name": "PvWindowStartHour", "caption": "Zeitfenster-Start [Uhr]", "digits": 1 },
        { "type": "NumberSpinner", "name": "PvWindowEndHour", "caption": "Zeitfenster-Ende [Uhr]", "digits": 1 }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "7 · Frostschutz",
      "items": [
        { "type": "Label", "caption": "Ohne Außentemperatur-Sensor inaktiv (fail-safe). PH-Schwelle muss unter UP-Schwelle liegen." },
        { "type": "NumberSpinner", "name": "FrostUpThreshold", "caption": "UP-Frostschwelle [°C]", "suffix": " °C", "digits": 1 },
        { "type": "NumberSpinner", "name": "FrostPhThreshold", "caption": "PH-Frostschwelle [°C]", "suffix": " °C", "digits": 1 },
        { "type": "NumberSpinner", "name": "FrostHysteresis", "caption": "Verlassens-Hysterese [K]", "suffix": " K", "digits": 1 }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "8 · Fault & Watchdog",
      "items": [
        { "type": "NumberSpinner", "name": "FaultBucketThreshold", "caption": "Leaky-Bucket Fault-Schwelle", "digits": 1 },
        { "type": "NumberSpinner", "name": "FaultBucketRecoverStep", "caption": "Bucket-Erholung pro Erfolg", "digits": 2, "minimum": 0.1, "maximum": 5 },
        { "type": "NumberSpinner", "name": "FaultBucketLeakRate", "caption": "Leak-Rate [pro Minute]", "digits": 4 },
        { "type": "NumberSpinner", "name": "VerifyDeadlineSec", "caption": "Verifikationsfrist [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "MaxRetries", "caption": "Max. Retries", "minimum": 1, "maximum": 10 },
        { "type": "NumberSpinner", "name": "QuittRateLimitSec", "caption": "Quittierungs-Rate-Limit [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "WatchdogPumpPlausSec", "caption": "UP Plausibilität [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "WatchdogPumpAbsSec", "caption": "UP Absolut-Grenze [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "WatchdogHeaterPlausSec", "caption": "PH Plausibilität [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "WatchdogHeaterAbsSec", "caption": "PH Absolut-Grenze [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "FaultEmergencyRunSec", "caption": "Notlauf-Dauer [s]", "suffix": " s" },
        { "type": "NumberSpinner", "name": "FaultEmergencyIntervalSec", "caption": "Notlauf-Intervall [s]", "suffix": " s" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "9 · Energie",
      "items": [
        { "type": "NumberSpinner", "name": "PumpPowerW", "caption": "UP Leistung Festwert [W] (Fallback + W1-Basis)", "suffix": " W" },
        { "type": "NumberSpinner", "name": "HeaterPowerW", "caption": "PH Leistung Festwert [W] (Fallback + W1-Basis)", "suffix": " W" },
        { "type": "NumberSpinner", "name": "ElectricityPrice", "caption": "Strompreis [€/kWh]", "suffix": " €/kWh", "digits": 4 }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "10 · System",
      "items": [
        { "type": "CheckBox", "name": "SimMode", "caption": "⚠ Simulationsbetrieb (Dry-Run) – schaltet keine Aktoren" },
        { "type": "NumberSpinner", "name": "CycleIntervalSec", "caption": "Zyklusintervall [s]", "suffix": " s", "minimum": 30, "maximum": 300 },
        { "type": "NumberSpinner", "name": "StaggerOffsetSec", "caption": "Anlauf-Offset [s] (Mehrfach-Instanzen)", "suffix": " s", "minimum": 0, "maximum": 60 }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "11 · Aktionen",
      "items": [
        { "type": "Button", "caption": "FAULT quittieren", "onClick": "IPS_RequestAction($id, 'AckFault', true);" },
        { "type": "Button", "caption": "Tagesreset", "onClick": "IPS_RequestAction($id, 'DayReset', true);" },
        { "type": "Button", "caption": "Konfiguration neu prüfen", "onClick": "IPS_ApplyChanges($id);" }
      ]
    }
  ],
  "status": [
    { "code": 102, "icon": "active", "caption": "Aktiv" },
    { "code": 104, "icon": "inactive", "caption": "Inaktiv" },
    { "code": 201, "icon": "error", "caption": "UP-Schaltziel ungültig" },
    { "code": 202, "icon": "error", "caption": "PH-Schaltziel ungültig" },
    { "code": 203, "icon": "error", "caption": "Pflicht-Sensor fehlt" },
    { "code": 204, "icon": "error", "caption": "Frost-Konfiguration ungültig" },
    { "code": 205, "icon": "error", "caption": "Umwälz-Konfiguration ungültig" },
    { "code": 206, "icon": "error", "caption": "Soll-Kurve ungültig" },
    { "code": 207, "icon": "error", "caption": "PV-Schwellenabstand zu klein (Takt-Gefahr)" },
    { "code": 208, "icon": "error", "caption": "PV-Zeitfenster ungültig" },
    { "code": 209, "icon": "error", "caption": "Tagesende vor letztem Stützpunkt" },
    { "code": 210, "icon": "error", "caption": "FAULT aktiv" }
  ]
}
